# Client environment variables for production builds
# ===================================================
# Set VITE_API_URL to your Render backend URL (no trailing slash)
#
# Example:
#   VITE_API_URL=https://weather-dashboard-api-xxxx.onrender.com
#
# In Vercel, set this via:
#   Dashboard → Project → Settings → Environment Variables

VITE_API_URL=https://your-render-backend-url.onrender.com
